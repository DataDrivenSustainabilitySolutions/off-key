# ----------------------------------------
# Backend and API Configuration
# ----------------------------------------
APP_NAME=off-key
JWT_
JWT_VERIFICATION_
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SUPERUSER_MAIL=oliver.hennhoefer@mail.de

# ----------------------------------------
# Email and SMTP Settings
# ----------------------------------------
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@example.com
SMTP_SERVER=mailpit
SMTP_PORT=1025
MAIL_STARTTLS=False
MAIL_SSL_TLS=False
USE_CREDENTIALS=False
VALIDATE_CERTS=False

ANOMALY_ALERT_RECIPIENTS="admin@example.com"  # Comma-separated list

# ----------------------------------------
# URL Configuration
# ----------------------------------------
FRONTEND_BASE_URL=http://localhost:5173
# CORS origins for API Gateway (JSON array format required).
# Development default:
CORS_ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:5173"]
# Production example (replace with your real domains):
# CORS_ALLOWED_ORIGINS=["https://app.example.com"]

# ----------------------------------------
# Database Configuration
# ----------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=timescaledb

# ----------------------------------------
# MQTT Integration
# ----------------------------------------
MQTT_BROKER_HOST=source-broker
MQTT_BROKER_PORT=1883
MQTT_USE_TLS=false
MQTT_TRANSPORT=tcp
MQTT_CLIENT_ID_PREFIX=offkey-backend
MQTT_USE_AUTH=false
MQTT_USERNAME=
MQTT_APIKEY=
MQTT_SOURCE_TOPICS=charger/+/live-telemetry/#
MQTT_TOPIC_REGEX=^charger/(?P<charger_id>[^/]+)/(?:telemetry|live-telemetry)/(?P<telemetry_type>.+)$
MQTT_TOPIC_PAYLOAD_CHARGER_KEY=charger_id
MQTT_TOPIC_PAYLOAD_TYPE_KEY=telemetry_type

MQTT_ENABLE_BRIDGE=true
MQTT_BRIDGE_BROKER_HOST=emqx-main
MQTT_BRIDGE_BROKER_PORT=1883
MQTT_BRIDGE_USE_TLS=false
MQTT_BRIDGE_TRANSPORT=tcp
MQTT_BRIDGE_CLIENT_ID_PREFIX=off-key-mqtt-bridge-client
MQTT_BRIDGE_USERNAME=
MQTT_BRIDGE_APIKEY=
MQTT_BRIDGE_USE_AUTH=false

MQTT_TELEMETRY_ENABLED=true
MQTT_RECONNECT_DELAY=5
MQTT_BATCH_SIZE=100
MQTT_MAX_MESSAGE_QUEUE_SIZE=10000
MQTT_BATCH_TIMEOUT=5
MQTT_WORKER_THREADS=4
MQTT_SUBSCRIPTION_QOS=1

MQTT_HEALTH_LOG_REMINDER_INTERVAL=10
MQTT_SHUTDOWN_TIMEOUT=10.0
MQTT_GRACEFUL_SHUTDOWN_TIMEOUT=30.0

# ----------------------------------------
# EMQX Dashboard Credentials
# ----------------------------------------
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change-me-emqx-dashboard-password

MQTT_RETRY_BASE_DELAY=0.1  # Base delay for exponential backoff (seconds)
MQTT_RETRY_MAX_DELAY=5.0  # Maximum delay cap for retries (seconds)
MQTT_RETRY_EXPONENTIAL_BASE=2.0  # Exponential growth rate (2.0 = standard)
MQTT_RETRY_JITTER_ENABLED=true  # Enable jitter to prevent thundering herd
MQTT_RETRY_JITTER_MAGNITUDE=0.2  # Jitter range (0.2 = ±20%)

MQTT_CLEANUP_INTERVAL=60.0  # Cleanup task runs every 60 seconds
MQTT_METRICS_INTERVAL=300.0  # Metrics reported every 5 minutes
MQTT_HEALTH_MONITOR_INTERVAL=30.0  # Health checks every 30 seconds

# ---------------------------------------------------
# MQTT Simulator (docker-compose --profile mqtt-sim)
# ---------------------------------------------------
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=1.0
SIMULATOR_CHARGER_IDS=charger-sim-1,charger-sim-2
SIMULATOR_FEATURES=sine,cosine,random
SIMULATOR_VALUE_MIN=0.0
SIMULATOR_VALUE_MAX=100.0
SIMULATOR_BLIP_PROBABILITY=0.0025
SIMULATOR_BLIP_MULTIPLIER_MIN=1.8
SIMULATOR_BLIP_MULTIPLIER_MAX=2.6

# ---------------------------------------------------
# RADAR Service Configuration (docker-compose mqtt-radar)
# ---------------------------------------------------
RADAR_MQTT_BROKER_HOST=emqx-main
RADAR_MQTT_BROKER_PORT=1883
RADAR_MQTT_USE_TLS=false
RADAR_SUBSCRIPTION_TOPICS=charger/+/live-telemetry/#
RADAR_HEURISTIC_ZSCORE_THRESHOLD=2.0

# ---------------------------------------------------
# TACTIC Middleware Service Environment Configuration
# ---------------------------------------------------
ENVIRONMENT=development
TACTIC_RADAR_WORKLOAD_LIFECYCLE=ephemeral
# Use persistent in production when RADAR workloads must survive TACTIC restarts.
# TACTIC_RADAR_WORKLOAD_LIFECYCLE=persistent

# Service Identity
TACTIC_SERVICE_NAME=tactic-middleware
TACTIC_SERVICE_VERSION=0.1.0
TACTIC_HOST=0.0.0.0
TACTIC_PORT=8000
TACTIC_LOG_LEVEL=INFO
TACTIC_SERVICE_HOST=tactic-middleware
TACTIC_SERVICE_PORT=8000

# Docker API Connection
TACTIC_DOCKER_API_URL=http://socket-proxy
TACTIC_DOCKER_API_PORT=2375
TACTIC_DOCKER_MAX_CONCURRENT_CALLS=5

# Container Defaults
TACTIC_DOCKER_DEFAULT_NETWORK=emqx-network
# For local development (no worker nodes), set to empty:
TACTIC_DOCKER_DEFAULT_CONSTRAINTS=
# For production Swarm clusters with worker nodes:
# TACTIC_DOCKER_DEFAULT_CONSTRAINTS='node.role == worker'
TACTIC_DOCKER_DEFAULT_RESTART_POLICY=on-failure
TACTIC_DOCKER_DEFAULT_RESTART_MAX_ATTEMPTS=3
TACTIC_DOCKER_DEFAULT_MEMORY_LIMIT=512m
TACTIC_DOCKER_DEFAULT_CPU_LIMIT=0.5

# Default MQTT Settings
TACTIC_RADAR_DEFAULT_MQTT_BROKER_HOST=emqx-main
TACTIC_RADAR_DEFAULT_MQTT_BROKER_PORT=1883
TACTIC_RADAR_DEFAULT_MQTT_USE_TLS=false
TACTIC_RADAR_DEFAULT_MQTT_CLIENT_ID_PREFIX=radar
TACTIC_RADAR_DEFAULT_MQTT_USE_AUTH=false
TACTIC_RADAR_DEFAULT_MQTT_QOS=0

# Default ML Model Configuration
TACTIC_RADAR_DEFAULT_MODEL_TYPE=isolation_forest

# Default Performance Settings
TACTIC_RADAR_DEFAULT_BATCH_SIZE=100
TACTIC_RADAR_DEFAULT_BATCH_TIMEOUT=1.0
TACTIC_RADAR_DEFAULT_MEMORY_LIMIT_MB=1000
TACTIC_RADAR_DEFAULT_CHECKPOINT_INTERVAL=10000

# Default Database Settings
TACTIC_RADAR_DEFAULT_DB_WRITE_ENABLED=true
TACTIC_RADAR_DEFAULT_DB_BATCH_SIZE=50
TACTIC_RADAR_DEFAULT_DB_BATCH_TIMEOUT=2.0

# Default Health and Monitoring Settings
TACTIC_RADAR_DEFAULT_HEALTH_CHECK_INTERVAL=30.0
TACTIC_RADAR_DEFAULT_LOG_LEVEL=INFO
TACTIC_RADAR_DEFAULT_RATE_LIMIT_PER_MINUTE=1000

# ----------------------------------------
# Docker Compose Port Variables
# ----------------------------------------
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ----------------------------------------
# Frontend Variables
# ----------------------------------------
VITE_API_URL=http://api-gateway:8000

# ----------------------------------------
# Database Sync Service
# ----------------------------------------
SYNC_HOSTNAME=db-sync
TELEMETRY_RETENTION_DAYS=14         # Days of telemetry to retain (2 weeks)

# API Server
SYNC_API_HOST=0.0.0.0
SYNC_API_PORT=8009

# ----------------------------------------
# Development
# ----------------------------------------
DEBUG=True
LOG_LEVEL=INFO
LOG_TRUNCATE_LENGTH=150
LOG_FILE=/tmp/service.log
# Path MUST be defined within the service context. Defaults to /tmp/<service-name>.log
# SERVICE_LOG_FILE=
LOG_FORMAT="simple"  # or json
LOG_CORRELATION_HEADER=X-Correlation-ID
LOG_REDACT_PII=True
LOG_PII_DEBUG_UNMASK=False
LOG_HEARTBEAT_INTERVAL_SECONDS=60
LOG_REPEAT_SUPPRESSION_SECONDS=60
ENABLE_REQUEST_LOGGING=True
ENABLE_PERFORMANCE_LOGGING=True
UVICORN_ACCESS_LOG_LEVEL=WARNING
SQLALCHEMY_LOG_LEVEL=WARNING
RATE_LIMIT_LOG_LEVEL=WARNING
