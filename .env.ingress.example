# ----------------------------------------
# External Ingress (VPN + upstream MQTT pull)
# Copy to .env.ingress.local and fill values.
# Run ingress mode with:
# docker compose --env-file .env --env-file .env.ingress.local \
#   -f docker-compose.yml -f docker-compose.ingress.yml up -d --build
# ----------------------------------------

# Login behavior for ingress-vpn:
# - `INGRESS_TS_AUTH_ONCE=true` (recommended) reuses persisted state and only logs in when needed.
# - `INGRESS_TS_AUTHKEY` is required for first login, optional after state is already persisted.
INGRESS_TS_AUTH_ONCE=true
INGRESS_TS_AUTHKEY=

# Optional: extra tailscale up args (example keeps DNS from source tailnet).
INGRESS_TS_EXTRA_ARGS=--accept-dns=false

# Required: provider-owned upstream MQTT endpoint reachable from ingress-vpn.
INGRESS_UPSTREAM_MQTT_HOST=
INGRESS_UPSTREAM_MQTT_PORT=1883

# Topics to pull from upstream broker into local source-broker bridge.
INGRESS_UPSTREAM_MQTT_TOPICS=#

# Optional upstream MQTT auth and TLS.
INGRESS_UPSTREAM_USE_TLS=false
# Optional: skip upstream TLS hostname verification (testing only).
INGRESS_UPSTREAM_TLS_INSECURE=false
INGRESS_UPSTREAM_USERNAME=
INGRESS_UPSTREAM_PASSWORD=
