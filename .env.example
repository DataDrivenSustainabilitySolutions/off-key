# Copy this file to .env before running Docker Compose. Values in this file are
# safe local-development defaults only; replace every credential in production.

# Application and HTTP
APP_NAME=off-key
ENVIRONMENT=development
DEBUG=false
BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:5173"]
VITE_API_URL=http://api-gateway:8000

# Authentication (must be distinct and at least 32 characters)
JWT_SECRET=change-me-local-signing-secret-000000
JWT_VERIFICATION_SECRET=change-me-local-verification-secret-000
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SUPERUSER_MAIL=admin@example.com

# Local Mailpit delivery
EMAIL_USERNAME=off-key
EMAIL_PASSWORD=change-me-local-mail-password
EMAIL_FROM=off-key@example.com
SMTP_SERVER=mailpit
SMTP_PORT=1025
MAIL_STARTTLS=false
MAIL_SSL_TLS=false
USE_CREDENTIALS=false
VALIDATE_CERTS=false
ANOMALY_ALERT_RECIPIENTS=admin@example.com

# PostgreSQL / TimescaleDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-postgres-password
POSTGRES_DB=off_key
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Local MQTT source and proxy
MQTT_BROKER_HOST=source-broker
MQTT_BROKER_PORT=1883
MQTT_USE_TLS=false
MQTT_USE_AUTH=false
MQTT_SOURCE_TOPICS=charger/+/live-telemetry/#
MQTT_TELEMETRY_ENABLED=true

# EMQX dashboard
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change-me-local-emqx-password
EMQX_NODE_COOKIE=change-me-local-emqx-cookie

# TACTIC-managed RADAR workloads
TACTIC_DOCKER_API_URL=http://socket-proxy
TACTIC_DOCKER_API_PORT=2375
TACTIC_RADAR_DEFAULT_MQTT_BROKER_HOST=emqx-main
TACTIC_RADAR_DEFAULT_MQTT_BROKER_PORT=1883
TACTIC_RADAR_DEFAULT_MQTT_USE_TLS=false
TACTIC_RADAR_DEFAULT_MQTT_USE_AUTH=false
TACTIC_RADAR_WORKLOAD_LIFECYCLE=ephemeral
TACTIC_SERVICE_HOST=tactic-middleware
TACTIC_SERVICE_PORT=8000

# Standalone RADAR profile
RADAR_MQTT_BROKER_HOST=emqx-main
RADAR_MQTT_BROKER_PORT=1883
RADAR_MQTT_USE_TLS=false
RADAR_MQTT_USE_AUTH=false
RADAR_SUBSCRIPTION_TOPICS=charger/charger-sim-1/live-telemetry/sine,charger/charger-sim-1/live-telemetry/cosine,charger/charger-sim-1/live-telemetry/random

# Internal service discovery
SYNC_HOSTNAME=db-sync
SYNC_API_HOST=0.0.0.0
SYNC_API_PORT=8009
TELEMETRY_RETENTION_DAYS=14

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=simple
LOG_REDACT_PII=true
LOG_PII_DEBUG_UNMASK=false
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Swarm image overrides (uncomment and pin immutable release tags for deployment)
# API_GATEWAY_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-api-gateway:latest
# FRONTEND_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-frontend:latest
# MQTT_PROXY_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-mqtt-proxy:latest
# MQTT_RADAR_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-mqtt-radar:latest
# TACTIC_MIDDLEWARE_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-tactic-middleware:latest
# DB_SYNC_IMAGE=ghcr.io/datadrivensustainabilitysolutions/off-key-db-sync:latest
