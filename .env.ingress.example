# ----------------------------------------
# External Ingress (Tailscale VPN + gost TCP forwarder → EMQX bridge)
# Copy to .env.ingress.local and fill values.
#
# Deploy with:
#   docker stack deploy \
#     -c docker-compose.swarm.yml \
#     -c docker-compose.ingress.yml \
#     off-key
#
# After deploy: configure an EMQX MQTT bridge (Data Integration → Bridges)
# pointing to mqtt-tailscale-bridge:1883. Set upstream auth, TLS, and topic
# subscriptions there — they are not managed by this compose file.
# ----------------------------------------

# Tailscale login behavior:
# - INGRESS_TS_AUTH_ONCE=true (recommended) reuses persisted state; only logs in when needed.
# - INGRESS_TS_AUTHKEY is required for the first login; optional after state is pre-seeded.
INGRESS_TS_AUTH_ONCE=true
INGRESS_TS_AUTHKEY=

# Optional: extra tailscale flags (e.g. --login-server, --hostname, --accept-dns=false).
INGRESS_TS_EXTRA_ARGS=--accept-dns=false

# Host path for persisted Tailscale state (must exist on the backend node before deploy).
# Seed with tailscaled.state from a pre-authenticated installation to avoid runtime auth.
INGRESS_TS_STATE_DIR=/opt/stacks/off-key/tailscale-ingress-state

# Required: MagicDNS .ts.net hostname of the vendor MQTT broker on the tailnet.
INGRESS_UPSTREAM_MQTT_HOST=
INGRESS_UPSTREAM_MQTT_PORT=1883
